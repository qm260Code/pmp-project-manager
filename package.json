{
  "name": "pmp-project-manager",
  "version": "1.0.0",
  "description": "PMP 5大过程组 10大知识领域项目管理控制中心",
  "main": "main.js",
  "scripts": {
    "dev": "npx serve -l 3000",
    "electron:dev": "electron .",
    "electron:build": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.bosch.pmp.manager",
    "productName": "BOSCH项目管理控制中心",
    "win": {
      "target": "portable"
    },
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "index.html",
      "main.js",
      "src/**/*"
    ]
  }
}
